# The build brief is a private working document, not part of the published
# project. Delete this line if you want it in the repo's history.
PROJECT_BRIEF_s2_chips_to_map.txt

# data is downloaded, never committed (EuroSAT MS is ~2 GB extracted)
data/

# large or regenerable outputs
outputs/*.pt
outputs/*.pth
outputs/*.npy
outputs/*.npz
outputs/*.tif
outputs/features/
# results.json IS committed: the README tables are generated from it, so it is
# the record of what was actually run.
!outputs/results.json
!outputs/band_stats.json
# The predicted land-cover maps are the deliverable of notebook 05 and are tiny
# (~60 KB each), so they are committed as evidence — a reviewer can open them in
# QGIS without running anything. The 6.7 MB RGB scene and the confidence raster
# stay out: both are regenerable and neither is a result.
!outputs/landcover_prediction.tif
!outputs/landcover_prediction_sam.tif

# python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.venv/
venv/

# notebooks
.ipynb_checkpoints/

# os / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# transfer archive from Drive; its contents are extracted into figures/ and outputs/
s2map_results.zip
